# =============================================================================
# CodeForge Environment Variables
# =============================================================================

# --- Authentication (Better Auth) ---
BETTER_AUTH_SECRET=          # Session signing key (required)
BETTER_AUTH_URL=http://localhost:3000  # App base URL (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/codeforge

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Kubernetes Access ---
# Leave all empty to use local kubeconfig (~/.kube/config).
# Set K8S_API_SERVER + K8S_AUTH_TOKEN for remote cluster access (e.g. from Vercel),
# optionally through Cloudflare Tunnel for API-only access.
# In-cluster access (ServiceAccount) is auto-detected.
K8S_API_SERVER=              # e.g. https://k8s.tkweb.site
K8S_AUTH_TOKEN=              # ServiceAccount or user token
K8S_SKIP_TLS_VERIFY=false   # Set true for self-signed certs
K8S_NAMESPACE=codelearn      # Namespace for code-server resources

# --- Code-Server ---
CODE_SERVER_DOMAIN=codelearn.tkweb.site         # Wildcard base for user hosts (<slug>.codelearn.tkweb.site)
CODE_SERVER_TLS_SECRET=wildcard-codelearn-tls   # TLS secret used by generated user ingresses
CODE_SERVER_IMAGE=ghcr.io/dedkola/codeforge-cs:latest  # Custom image with template seeding + pnpm
CODE_SERVER_IMAGE_PULL_SECRET=           # Optional: docker-registry secret name in K8S_NAMESPACE
CODE_SERVER_PORT=8080                    # code-server listen port inside the container
CODE_SERVER_STORAGE_CLASS=local-path
CODE_SERVER_PVC_SIZE=1Gi
CODE_SERVER_MAX_IDLE_MINUTES=120
CODE_SERVER_POD_READY_TIMEOUT_MS=15000
CODE_SERVER_CLEANUP_SECRET=             # Bearer token for cleanup CronJob
CODE_SERVER_INGRESS_CLASS=traefik       # Kubernetes ingress controller class
CODE_SERVER_CLUSTER_ISSUER=letsencrypt-dns-prod  # cert-manager ClusterIssuer name
CODE_SERVER_MEMORY_REQUEST=256Mi
CODE_SERVER_CPU_REQUEST=100m
CODE_SERVER_MEMORY_LIMIT=512Mi
CODE_SERVER_CPU_LIMIT=500m

# --- Next.js ---
ALLOWED_DEV_ORIGINS=192.168.0.192       # Comma-separated list of allowed dev origins
