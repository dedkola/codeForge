# =============================================================================
# CodeForge Environment Variables
# =============================================================================

# --- Authentication (Better Auth) ---
BETTER_AUTH_SECRET=          # Session signing key (required)
BETTER_AUTH_URL=http://localhost:3000  # App base URL (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/codeforge

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Kubernetes Access ---
# Leave all empty to use local kubeconfig (~/.kube/config).
# Set K8S_API_SERVER + K8S_AUTH_TOKEN for remote cluster access (e.g. from Vercel).
# In-cluster access (ServiceAccount) is auto-detected.
K8S_API_SERVER=              # e.g. https://10.0.0.1:6443
K8S_AUTH_TOKEN=              # ServiceAccount or user token
K8S_SKIP_TLS_VERIFY=false   # Set true for self-signed certs
K8S_NAMESPACE=codelearn      # Namespace for code-server resources

# --- Code-Server ---
CODE_SERVER_DOMAIN=tkweb.site            # Wildcard domain for per-user subdomains
CODE_SERVER_IMAGE=ghcr.io/coder/code-server:4.105.2
CODE_SERVER_STORAGE_CLASS=local-path
CODE_SERVER_PVC_SIZE=1Gi
CODE_SERVER_MAX_IDLE_MINUTES=120
CODE_SERVER_POD_READY_TIMEOUT_MS=15000
CODE_SERVER_TLS_SECRET=cs-wildcard-tls  # K8s TLS secret for *.CODE_SERVER_DOMAIN
CODE_SERVER_CLEANUP_SECRET=             # Bearer token for cleanup CronJob
