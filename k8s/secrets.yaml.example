apiVersion: v1
kind: Secret
metadata:
  name: codeforge-secrets
type: Opaque
stringData:
  CODEFORGE_APP_URL: "https://codeforge.tkweb.site"
  CODE_SERVER_DOMAIN: "codelearn.tkweb.site"
  CODE_SERVER_TLS_SECRET: "wildcard-codelearn-tls"
  CODE_SERVER_IMAGE: "ghcr.io/dedkola/codeforge-cs:latest"
  CODE_SERVER_CLEANUP_SECRET: "replace-with-random-64-char-secret"
  BETTER_AUTH_SECRET: "your-secret-here"
  BETTER_AUTH_URL: "https://codeforge.tkweb.site"
  DATABASE_URL: "your-database-url-here"
  GITHUB_CLIENT_ID: "your-github-client-id"
  GITHUB_CLIENT_SECRET: "your-github-client-secret"
  GOOGLE_CLIENT_ID: "your-google-client-id"
  GOOGLE_CLIENT_SECRET: "your-google-client-secret"
